{
  "name": "rescue-link-root",
  "private": true,
  "workspaces": [
    "my-app",
    "backend"
  ],
  "scripts": {
    "build": "npm run build --workspace=my-app",
    "dev": "concurrently \"cd backend && npm run dev\" \"cd my-app && npm run dev\"",
    "install-all": "npm install && cd backend && npm install && cd ../my-app && npm install"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "nodemon": "^3.1.14"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}